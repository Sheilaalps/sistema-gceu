generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model membros {
  id              Int             @id @default(autoincrement())
  nome            String          @db.VarChar(100)
  telefone        String?         @db.VarChar(20)
  endereco        String?         @db.VarChar(255)
  data_nascimento DateTime?       @db.Date
  anfitriao_id    Int?
  anfitriao       usuarios?       @relation(fields: [anfitriao_id], references: [id], onDelete: SetNull)
  status          membros_status? @default(ativo)
  ultima_presenca DateTime?       @db.Date
  data_cadastro   DateTime?       @default(now()) @db.Timestamp(3)
  
  @@index([anfitriao_id])
}

enum membros_status {
  ativo
  ausente
  visitante
}

model usuarios {
  id       Int       @id @default(autoincrement())
  nome     String    @db.VarChar(100)
  email    String    @unique @db.VarChar(100)
  senha    String    @db.VarChar(255)
  nivel    usuarios_nivel @default(lider)
  membros  membros[]
}

enum usuarios_nivel {
  admin
  lider
  anfitriao
}